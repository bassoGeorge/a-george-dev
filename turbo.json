{
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["clean", "^build"],
      "outputs": ["dist/**"],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "!src/**/*.spec.tsx",
        "!src/**/*.spec.ts",
        "!src/**/*.stories.ts",
        "!src/**/*.stories.tsx"
      ]
    },
    "clean": {},
    "build:storybook": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "stories/**/*.ts"],
      "outputs": ["storybook-static/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.spec.tsx", "src/**/*.spec.ts", "vitest.config.ts"]
    },
    "dev": {
      "cache": false,
      "interactive": false,
      "persistent": true
    },
    "dev:storybook": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "e2e": {
      "cache": false,
      "passThroughEnv": ["BASE_URL"]
    },
    "//#format-and-lint": {},
    "//#format-and-lint:fix": {
      "cache": false
    }
  }
}
