{
  "name": "@ageorgedev/dnd-character-sheet",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "rm -rf ./dist",
    "build": "tsc && cpx \"src/**/*.css\" dist",
    "dev": "concurrently 'tsc --watch' 'cpx \"src/**/*.css\" dist --watch'",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./models": {
      "import": "./dist/lib/models/index.js",
      "types": "./dist/lib/models/index.d.ts"
    }
  },
  "peerDependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@ageorgedev/testing-config": "workspace:*",
    "@ageorgedev/ts-config": "workspace:*",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/ejs": "^3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "10.0.3",
    "cpx2": "9.0.0",
    "typescript": "5.8.3",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "@ageorgedev/toolbelt": "workspace:*",
    "dompurify": "3.4.11",
    "ejs": "^3.1.10",
    "ramda": "0.32.0"
  }
}
