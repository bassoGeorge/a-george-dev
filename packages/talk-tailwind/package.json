{
  "name": "@ageorgedev/talk-tailwind",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "clean": "rm -rf ./dist",
    "build": "tsc && cpx \"src/**/*.css\" dist",
    "dev": "concurrently 'tsc --watch' 'cpx \"src/**/*.css\" dist --watch' "
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "@ageorgedev/brand-components": "workspace:*",
    "@ageorgedev/design-system": "workspace:*",
    "@ageorgedev/reveal-framework": "workspace:*",
    "@ageorgedev/toolbelt": "workspace:*",
    "@phosphor-icons/react": "2.1.10"
  },
  "peerDependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "concurrently": "10.0.3",
    "cpx2": "9.0.0",
    "typescript": "5.8.3"
  }
}
