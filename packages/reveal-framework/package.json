{
  "name": "@ageorgedev/reveal-framework",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "clean": "rm -rf ./dist",
    "build": "tsc && cpx \"src/**/*.css\" dist",
    "dev": "concurrently 'tsc --watch' 'cpx \"src/**/*.css\" dist --watch' ",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./globals": {
      "import": "./dist/globals.js",
      "types": "./dist/globals.d.ts"
    }
  },
  "dependencies": {
    "@ageorgedev/design-system": "workspace:*",
    "@ageorgedev/toolbelt": "workspace:*",
    "@phosphor-icons/react": "2.1.10",
    "@revealjs/react": "0.2.0",
    "reveal.js": "6.0.0"
  },
  "peerDependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@ageorgedev/testing-config": "workspace:*",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@types/reveal.js": "4.4.2",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "10.0.3",
    "cpx2": "9.0.0",
    "typescript": "5.8.3",
    "vitest": "4.1.8"
  }
}
