{
  "name": "@ageorgedev/reveal-framework",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "rm -rf ./dist && tsc && cpx \"src/**/*.css\" dist"
  },
  "exports": {
    ".": {
      "local-dev": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./globals": {
      "local-dev": "./src/globals.ts",
      "import": "./dist/globals.js",
      "types": "./dist/globals.d.ts"
    }
  },
  "dependencies": {
    "@ageorgedev/design-system": "workspace:*",
    "@ageorgedev/toolbelt": "workspace:*",
    "@phosphor-icons/react": "2.1.10",
    "@revealjs/react": "^0.2.0",
    "react": "19.1.0",
    "reveal.js": "6.0.0"
  },
  "devDependencies": {
    "@types/reveal.js": "^4.4.2"
  }
}
