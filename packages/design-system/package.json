{
  "name": "@ageorgedev/design-system",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "clean": "rm -rf ./dist",
    "build": "tsc && cpx \"src/**/*.css\" dist",
    "dev": "concurrently 'tsc --watch' 'cpx \"src/**/*.css\" dist --watch' ",
    "test": "vitest run"
  },
  "exports": {
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "dependencies": {
    "@ageorgedev/toolbelt": "workspace:*",
    "@phosphor-icons/react": "2.1.10",
    "@radix-ui/react-slot": "1.2.3",
    "class-variance-authority": "0.7.1",
    "ramda": "0.32.0",
    "react-syntax-highlighter": "16.1.1"
  },
  "devDependencies": {
    "@ageorgedev/testing-config": "workspace:*",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "10.0.3",
    "cpx2": "9.0.0",
    "jsdom": "29.1.1",
    "typescript": "5.8.3",
    "typescript-plugin-css-modules": "5.2.0",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
