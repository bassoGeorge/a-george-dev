{
  "name": "@ageorgedev/toolbelt",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf ./dist && tsc",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "exports": {
    "./*": {
      "local-dev": "./src/*.ts",
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "dependencies": {
    "clsx": "2.1.1",
    "ramda": "0.28.0",
    "tailwind-merge": "3.3.1"
  },
  "devDependencies": {
    "@ageorgedev/ts-config": "workspace:*",
    "@types/ramda": "0.28.23",
    "@vitest/ui": "4.1.8",
    "typescript": "5.8.3",
    "vitest": "4.1.8"
  }
}
