{
  "name": "a-george-dev",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "dev": "turbo dev --filter=\"@ageorgedev/ageorgedev...\"",
    "build": "turbo @ageorgedev/ageorgedev#build",
    "test": "turbo test -- --passWithNoTests",
    "preinstall": "git config core.hooksPath .git-hooks",
    "clean-dist": "rm -rf dist && find ./libs -type d -name dist -exec rm -rf {} + && find ./apps -type d -name dist -exec rm -rf {} +",
    "storybook": "turbo @ageorgedev/design-docs#dev:storybook",
    "decap-server": "npx decap-server",
    "shadcn": "yarn dlx shadcn",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "lint:ci": "biome ci .",
    "affected:apps": "yarn turbo query affected --packages | jq -c '[.data.affectedPackages.items[] | select(.path | contains(\"apps/\")) | select(.name  | endswith(\"-e2e\") | not) | .name ]'"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "concurrently": "10.0.3",
    "knip": "6.15.0",
    "syncpack": "15.3.1",
    "turbo": "2.9.16"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=24.15.0"
  },
  "volta": {
    "node": "24.15.0",
    "yarn": "4.14.1"
  }
}
