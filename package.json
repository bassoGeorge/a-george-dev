{
  "name": "a-george-dev",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "dev": "turbo @ageorgedev/ageorgedev#dev",
    "build": "turbo @ageorgedev/ageorgedev#build",
    "test": "turbo test -- --passWithNoTests",
    "preinstall": "git config core.hooksPath .git-hooks",
    "clean-dist": "rm -rf dist && find ./libs -type d -name dist -exec rm -rf {} + && find ./apps -type d -name dist -exec rm -rf {} +",
    "storybook": "turbo @ageorgedev/design-docs#dev:storybook",
    "decap-server": "npx decap-server",
    "shadcn": "yarn dlx shadcn",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "lint:ci": "biome ci .",
    "affected:apps": "yarn turbo query affected --packages | jq -c '[.data.affectedPackages.items[] | select(.path | contains(\"apps/\")) | select(.name  | endswith(\"-e2e\") | not) | .name ]'"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/preset-react": "^7.29.7",
    "@biomejs/biome": "2.4.16",
    "@storybook/addon-a11y": "^9.0.17",
    "@storybook/addon-themes": "9.0.17",
    "@storybook/react-vite": "9.0.17",
    "@swc-node/register": "1.9.2",
    "@swc/cli": "0.6.0",
    "@swc/core": "1.5.7",
    "@swc/helpers": "0.5.17",
    "@types/node": "18.16.9",
    "@types/ramda": "^0.28.23",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.13",
    "cpx2": "^9.0.0",
    "cypress": "14.4.0",
    "jiti": "2.4.2",
    "jsdom": "22.1.0",
    "knip": "^6.15.0",
    "postcss": "^8.5.15",
    "postcss-nesting": "^12.1.5",
    "sass": "^1.55.0",
    "syncpack": "^15.3.1",
    "tailwindcss": "^4.1.8",
    "ts-node": "10.9.1",
    "turbo": "^2.9.16",
    "typescript": "5.8.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "4.5.4",
    "vite-tsconfig-paths": "4.2.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "@fontsource-variable/alegreya": "^5.2.8",
    "@fontsource-variable/source-code-pro": "^5.2.7",
    "@fontsource/alegreya-sans": "^5.2.8",
    "@fontsource/alegreya-sans-sc": "^5.2.7",
    "@mdx-js/loader": "3.1.0",
    "@mdx-js/react": "3.1.0",
    "@phosphor-icons/react": "2.1.10",
    "@tailwindcss/postcss": "^4.1.10",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.170.11",
    "@tanstack/react-start": "^1.168.19",
    "@types/mdx": "^2.0.13",
    "@types/react-syntax-highlighter": "^15.5.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.522.0",
    "param-case": "^3.0.4",
    "ramda": "^0.28.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-syntax-highlighter": "16.1.1",
    "remark-frontmatter": "5.0.0",
    "remark-mdx-frontmatter": "5.2.0",
    "storybook": "^10.4.2",
    "tailwind-merge": "^3.3.1",
    "tslib": "^2.3.0",
    "tw-animate-css": "^1.3.4"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "volta": {
    "node": "24.15.0",
    "yarn": "4.14.1"
  },
  "resolutions": {
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6"
  }
}
